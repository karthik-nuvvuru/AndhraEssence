# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-super-secret-key-in-production-min-32-chars
API_VERSION=v1
APP_NAME=AndhraEssence

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/andhraessence
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Demo Mode (uses SQLite instead of PostgreSQL - no external DB needed)
DEMO_MODE=false
SQLITE_DATABASE_PATH=andhraessence_demo.db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Razorpay (Payments) - Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Twilio (SMS) - Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 (Alternative SMS for India)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=ANDESS
MSG91_TEMPLATE_ID=your-template-id

# Firebase (Push Notifications) - Get from Firebase Console
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Google Maps Platform - Get from https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@andhraessence.com

# Admin (Initial setup)
ADMIN_EMAIL=admin@andhraessence.com
ADMIN_PASSWORD=change-this-admin-password

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
